<script>
    window.addEventListener("scroll", () => {
        const bgFix = document.querySelector(".bg-fix");
        const splashVideo = document.getElementById('splash');
        const scrollY = window.scrollY;
        // console.log(scrollY);

        const maxScroll = window.innerHeight * 0.6; //80vh en pixels

        // Calcul progressif du blur et du sepia
        const blurValue = Math.min((scrollY / maxScroll) * 5, 5); // Blur jusqu'à 10px
        const sepiaValue = Math.min((scrollY / maxScroll), 1); // Sepia jusqu'à 1 (100%)
        const brightnessValue = Math.min((scrollY / maxScroll) * 0.5, 0.5); // Brightness jusqu'à 0.5

        // Appliquer les valeurs en CSS variables
        bgFix.style.setProperty("--blur-value", `${blurValue}px`);
        bgFix.style.setProperty("--sepia-value", sepiaValue);
        bgFix.style.setProperty("--brightness-value", 1 - brightnessValue);

        if (scrollY >= 100) {
            // splashVideo.play();
        }
    });
