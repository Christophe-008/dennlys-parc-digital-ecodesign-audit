            <script type="module">
    const now = new Date();
    normaliserHeures(now);

    import {
        events
    } from "./../../date.js";

    function normaliserHeures(date) {
        date.setHours(0, 0, 0, 0);
    }

    function parserDateUS(dateStr) {
        const [month, day, year] = dateStr.split('/').map(Number);
        const d = new Date(year, month - 1, day);
        normaliserHeures(d);
        return d;
    }

    function estDateValide(eventDate) {
        if (Array.isArray(eventDate)) {
            const [dateStart, dateEnd] = eventDate.map(parserDateUS);
            return dateStart <= now && now <= dateEnd;
        } else {
            const date = parserDateUS(eventDate);
            return now.getTime() === date.getTime();
        }
    }

    const balise = document.querySelector('#horaires small');

    if (balise) {
        let trouve = false;

        events.some(element => {
            if (estDateValide(element.date)) {
                console.log(element.description);
                balise.innerText = element.description;
                trouve = true;
                return true;
            }
            return false;
        });

        if (!trouve) {
            balise.innerText = "Parc fermé aujourd'hui";
        }
    }
</script>



